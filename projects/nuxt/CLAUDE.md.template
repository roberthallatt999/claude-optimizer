## Nuxt 3 Patterns

### Page with Data Fetching
```vue
<!-- pages/posts/[id].vue -->
<script setup lang="ts">
// Route params are auto-typed
const route = useRoute();

// useFetch: SSR-friendly, cached, auto-refreshed on route change
const { data: post, pending, error } = await useFetch(`/api/posts/${route.params.id}`, {
  key: `post-${route.params.id}`,
});

// SEO meta
useSeoMeta({
  title: () => post.value?.title ?? 'Post',
  description: () => post.value?.excerpt,
});
</script>

<template>
  <div>
    <div v-if="pending">Loading...</div>
    <article v-else-if="post">
      <h1>{{ post.title }}</h1>
      <div v-html="post.content" />
    </article>
    <div v-else-if="error">{{ error.message }}</div>
  </div>
</template>
```

### Server API Route
```ts
// server/api/posts/[id].get.ts — GET /api/posts/:id
export default defineEventHandler(async (event) => {
  const id = getRouterParam(event, 'id');
  if (!id) throw createError({ statusCode: 400, statusMessage: 'ID required' });

  const post = await db.post.findUnique({ where: { id } });
  if (!post) throw createError({ statusCode: 404, statusMessage: 'Not Found' });

  return post;
});

// server/api/posts/index.post.ts — POST /api/posts
export default defineEventHandler(async (event) => {
  const session = await requireUserSession(event);
  const body = await readValidatedBody(event, postCreateSchema.parse);
  return db.post.create({ data: { ...body, authorId: session.user.id } });
});
```

### Pinia Store
```ts
// stores/auth.ts
export const useAuthStore = defineStore('auth', () => {
  const user = ref<User | null>(null);
  const isAuthenticated = computed(() => !!user.value);

  async function login(email: string, password: string) {
    const { data } = await useFetch('/api/auth/login', {
      method: 'POST',
      body: { email, password },
    });
    user.value = data.value?.user ?? null;
  }

  function logout() {
    user.value = null;
    navigateTo('/login');
  }

  return { user, isAuthenticated, login, logout };
});
```

### Composables (Auto-Imported)
```ts
// composables/usePostActions.ts
export function usePostActions() {
  const postStore = usePostStore();

  async function publish(id: string) {
    await $fetch(`/api/posts/${id}/publish`, { method: 'PATCH' });
    await postStore.refresh();
  }

  return { publish };
}
```

### Route Middleware (Auth Guard)
```ts
// middleware/auth.ts — named middleware
export default defineNuxtRouteMiddleware(() => {
  const { isAuthenticated } = useAuthStore();
  if (!isAuthenticated) return navigateTo('/login');
});
```

```vue
<!-- In page: apply middleware -->
<script setup lang="ts">
definePageMeta({ middleware: 'auth' });
</script>
```

