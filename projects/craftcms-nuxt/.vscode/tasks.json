{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "DDEV: Start",
      "type": "shell",
      "command": "ddev start",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "DDEV: Stop",
      "type": "shell",
      "command": "ddev stop",
      "problemMatcher": []
    },
    {
      "label": "DDEV: Xdebug On",
      "type": "shell",
      "command": "ddev xdebug on",
      "problemMatcher": []
    },
    {
      "label": "DDEV: Xdebug Off",
      "type": "shell",
      "command": "ddev xdebug off",
      "problemMatcher": []
    },
    {
      "label": "Craft: Clear Caches",
      "type": "shell",
      "command": "ddev exec php craft clear-caches/all",
      "problemMatcher": []
    },
    {
      "label": "Craft: Apply Migrations",
      "type": "shell",
      "command": "ddev exec php craft migrate/all",
      "problemMatcher": []
    },
    {
      "label": "Craft: Apply Project Config",
      "type": "shell",
      "command": "ddev exec php craft project-config/apply",
      "problemMatcher": []
    },
    {
      "label": "Nuxt: Dev Server",
      "type": "shell",
      "command": "cd frontend && npm run dev",
      "problemMatcher": [],
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Nuxt: Build",
      "type": "shell",
      "command": "cd frontend && npm run build",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Nuxt: Generate (SSG)",
      "type": "shell",
      "command": "cd frontend && npm run generate",
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
