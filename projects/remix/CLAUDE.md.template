## Remix Patterns

### Route with Loader and Action
```tsx
// app/routes/posts.$id.tsx
import type { LoaderFunctionArgs, ActionFunctionArgs } from '@remix-run/node';
import { json, redirect } from '@remix-run/node';
import { useLoaderData, Form } from '@remix-run/react';
import { z } from 'zod';
import { db } from '~/lib/db.server';
import { requireAuth } from '~/lib/auth.server';

export async function loader({ params, request }: LoaderFunctionArgs) {
  const user = await requireAuth(request);
  const post = await db.post.findUnique({ where: { id: params.id } });
  if (!post) throw new Response('Not Found', { status: 404 });
  return json({ post, user });
}

const updateSchema = z.object({
  title: z.string().min(1).max(200),
  content: z.string().min(1),
});

export async function action({ params, request }: ActionFunctionArgs) {
  const user = await requireAuth(request);
  const formData = await request.formData();
  const result = updateSchema.safeParse(Object.fromEntries(formData));

  if (!result.success) {
    return json({ errors: result.error.flatten().fieldErrors }, { status: 400 });
  }

  await db.post.update({ where: { id: params.id }, data: result.data });
  return redirect('/posts');
}

export default function PostEdit() {
  const { post } = useLoaderData<typeof loader>();

  return (
    <Form method="post">
      <input name="title" defaultValue={post.title} />
      <textarea name="content" defaultValue={post.content} />
      <button type="submit">Save</button>
    </Form>
  );
}
```

### Error Boundaries
```tsx
// In any route file
export function ErrorBoundary() {
  const error = useRouteError();

  if (isRouteErrorResponse(error)) {
    return (
      <div>
        <h1>{error.status} {error.statusText}</h1>
        <p>{error.data}</p>
      </div>
    );
  }

  return <div>Unknown error</div>;
}
```

### Authentication Guard
```ts
// app/lib/auth.server.ts
import { redirect } from '@remix-run/node';
import { getSession } from './session.server';

export async function requireAuth(request: Request) {
  const session = await getSession(request.headers.get('Cookie'));
  const userId = session.get('userId');
  if (!userId) throw redirect('/login');
  return userId;
}
```

### Optimistic UI
```tsx
import { useFetcher } from '@remix-run/react';

function LikeButton({ postId, liked }: { postId: string; liked: boolean }) {
  const fetcher = useFetcher();
  const isLiked = fetcher.formData
    ? fetcher.formData.get('liked') === 'true'
    : liked;

  return (
    <fetcher.Form method="post" action="/api/posts/like">
      <input type="hidden" name="postId" value={postId} />
      <input type="hidden" name="liked" value={String(!isLiked)} />
      <button type="submit">{isLiked ? '♥' : '♡'}</button>
    </fetcher.Form>
  );
}
```

### Parallel Data Loading
```tsx
// Loaders run in parallel per route segment by default
// For client-side parallel fetching:
import { useLoaderData } from '@remix-run/react';

export async function loader() {
  const [users, posts] = await Promise.all([
    db.user.findMany(),
    db.post.findMany({ where: { published: true } }),
  ]);
  return json({ users, posts });
}
```

## Coding Standards

### Server vs Client
- `.server.ts` suffix prevents accidental client bundling
- Never import `db`, secrets, or server-only utilities without `.server.ts` suffix
- Loaders and actions are always server-side — use them for data and mutations

### Form Handling
- Use Remix `Form`/`useFetcher` instead of `fetch` for mutations
- Use Conform (`@conform-to/react`) for complex form validation with Zod
- Return validation errors from `action` — show them with `useActionData`

### Type Safety
- Always type `useLoaderData<typeof loader>()` — gives accurate inferred types
- Use `json()` utility for consistent serialization
- Prefer `throw new Response(...)` over returning error objects

## Performance

- Loaders run in parallel across nested routes — design routes to exploit this
- Use `prefetch="intent"` on `<Link>` for preloading
- Stream slow data with `defer()` + `<Awaited>` (Remix Streaming)
- Use `staleWhileRevalidate` cache headers for public data

## Important Notes

1. **No `useEffect` for data fetching** — always use loaders
2. **Forms over fetch** — Remix Form is progressive-enhancement-safe
3. **`_` prefix** — pathless layout routes (e.g., `_app.tsx`)
4. **`.server.ts`** — required suffix for server-only modules

