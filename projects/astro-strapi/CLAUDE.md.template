## API Integration

### Strapi REST API Client

```typescript
// frontend/src/lib/strapi.ts
const STRAPI_URL = import.meta.env.STRAPI_URL || 'http://localhost:1337';
const STRAPI_TOKEN = import.meta.env.STRAPI_TOKEN;

interface StrapiResponse<T> {
  data: T;
  meta: { pagination?: { page: number; pageSize: number; total: number } };
}

export async function fetchStrapi<T>(
  endpoint: string,
  params?: Record<string, string>
): Promise<StrapiResponse<T>> {
  const url = new URL(`/api${endpoint}`, STRAPI_URL);
  if (params) {
    Object.entries(params).forEach(([key, value]) => url.searchParams.set(key, value));
  }

  const res = await fetch(url.toString(), {
    headers: {
      'Content-Type': 'application/json',
      ...(STRAPI_TOKEN && { 'Authorization': `Bearer ${STRAPI_TOKEN}` }),
    },
  });

  if (!res.ok) throw new Error(`Strapi error: ${res.status}`);
  return res.json();
}

// Convenience helpers
export async function getArticles(limit = 10) {
  return fetchStrapi('/articles', {
    'populate': '*',
    'sort': 'publishedAt:desc',
    'pagination[pageSize]': String(limit),
  });
}

export async function getArticle(slug: string) {
  return fetchStrapi('/articles', {
    'filters[slug][$eq]': slug,
    'populate': '*',
  });
}
```

### Using in Astro Pages

```astro
---
// src/pages/blog/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getArticles } from '@/lib/strapi';

const { data: articles } = await getArticles(10);
---

<BaseLayout title="Blog">
  <h1>Blog</h1>
  {articles.map((article) => (
    <article>
      <a href={`/blog/${article.attributes.slug}`}>
        <h2>{article.attributes.title}</h2>
      </a>
      <p>{article.attributes.excerpt}</p>
    </article>
  ))}
</BaseLayout>
```

### Dynamic Routes (SSG)

```astro
---
// src/pages/blog/[slug].astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getArticles, getArticle } from '@/lib/strapi';

export async function getStaticPaths() {
  const { data: articles } = await getArticles(100);
  return articles.map((article) => ({
    params: { slug: article.attributes.slug },
  }));
}

const { slug } = Astro.params;
const { data: articles } = await getArticle(slug);
const article = articles[0];
---

<BaseLayout title={article.attributes.title}>
  <article>
    <h1>{article.attributes.title}</h1>
    <div set:html={article.attributes.content} />
  </article>
</BaseLayout>
```

## Astro Patterns

### Layouts
```astro
---
// src/layouts/BaseLayout.astro
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
</head>
<body>
  <slot />
</body>
</html>
```

### Islands Architecture (Interactive Components)
```astro
---
import Counter from '@/components/interactive/Counter.tsx';
---

<!-- Static by default -->
<h1>Static heading</h1>

<!-- Hydrate on client -->
<Counter client:load />           <!-- Immediate hydration -->
<Counter client:visible />        <!-- Hydrate when visible -->
<Counter client:idle />           <!-- Hydrate on idle -->
<Counter client:media="(min-width: 768px)" />  <!-- Hydrate on media query -->
```

## Coding Standards

### TypeScript
- Use strict mode; define types for all Strapi responses
- Avoid `any` type

### Astro
- Use `.astro` for static components (default)
- Use React/Vue/Svelte only for interactive islands
- Keep frontmatter (`---`) minimal; extract logic to `lib/`

### CSS
- Use Tailwind utility classes
- Mobile-first responsive design
- Scoped styles in `.astro` files when needed

## Important Notes

1. **Strapi admin**: First-time setup requires creating an admin user at `/admin`
2. **API permissions**: Configure in Strapi admin > Settings > Users & Permissions > Roles
3. **Environment variables**: Strapi uses `.env`, Astro uses `import.meta.env` (prefix with `PUBLIC_` for client)
4. **Media URLs**: Strapi returns relative URLs; prepend `STRAPI_URL` in frontend
5. **Webhooks**: Configure Strapi webhooks to trigger Astro rebuilds on content changes
6. **Draft/Preview**: Use Strapi's draft system with Astro's SSR mode for previews

